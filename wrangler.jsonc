{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "prime-fashion-arabia",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public",
  },
  "observability": {
    "enabled": true,
  },
}
